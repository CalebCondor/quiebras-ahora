---
import { MapPin, Phone } from "@lucide/astro";
import { FaWhatsapp } from "react-icons/fa";

const offices = [
  {
    city: "Área Metro",
    address: "Av. San Patricio 785, San Juan",
    query: "Avenida San Patricio 785, San Juan, PR",
    mainPhone: "(787) 787-4747",
    whatsapp: "17872490725",
    phones: [
      "1-800-981-7133",
      "(787) 781-5635",
      "(787) 273-7143",
      "(787) 783-6615",
    ],
  },
  {
    city: "Bayamón",
    address: "Urb. Riverview, Calle 25 DD16",
    query: "Calle 25, Bayamón, Puerto Rico",
    mainPhone: "(787) 787-4747",
    whatsapp: "17872490725",
    phones: ["(787) 787-4747", "(787) 787-4775", "1-800-664-0088"],
  },
  {
    city: "Caguas",
    address: "Urb. Santa Juana, calle 19 # R",
    query: "Urb. Santa Juana, calle 19 # R8, Caguas, PR",
    mainPhone: "(787) 746-5266",
    whatsapp: "17872490725",
    phones: ["(787) 746-5266", "(787) 746-5288", "1-800-501-0088"],
  },
];
---

<section class="py-12 pt-26 px-5 bg-gray-50">
  <!-- Header -->
  <div class="text-center mb-10 px-2 max-w-4xl mx-auto">
    <p class="text-gray-700 text-3xl md:text-5xl font-semibold leading-snug">
      Llámenos y obtenga una <span class="text-primary font-bold"
        >orientación gratuita</span
      >
      y sin compromiso
    </p>
  </div>

  <!-- Offices List -->
  <div class="grid grid-cols-1 md:grid-cols-3 gap-8 max-w-7xl mx-auto">
    {
      offices.map((office) => (
        <div class="bg-white overflow-hidden md:shadow-sm md:hover:shadow-md transition-shadow">
          <!-- City Name -->
          <div class="px-6 pt-6 pb-2 text-center">
            <h3 class="text-3xl font-['Georgia'] font-bold italic text-primary leading-tight">
              {office.city}
            </h3>
          </div>

          <!-- Main Phone -->
          <div class="px-6 py-4 text-center">
            <a
              href={`tel:${office.mainPhone.replace(/\D/g, "")}`}
              class="block text-4xl font-light text-gray-900 tracking-tight font-['Montserrat'] hover:text-primary transition-colors"
            >
              {office.mainPhone}
            </a>
          </div>

          <!-- Address -->
          <div class="px-6 pb-4 text-center">
            <p class="text-gray-500 text-xl font-['Montserrat'] leading-relaxed">{office.address}</p>
          </div>

          <!-- Map Embed -->
          <div class="relative w-full h-44 overflow-hidden">
            <iframe
              width="100%"
              height="100%"
              style="border:0"
              loading="lazy"
              src={`https://maps.google.com/maps?q=${encodeURIComponent(office.query)}&t=&z=15&ie=UTF8&iwloc=&output=embed`}
              class="w-full h-full"
            />
          </div>

          <!-- Map Links -->
          <div class="px-6 py-3 text-center border-t font-['Montserrat'] border-gray-100">
            <a
              href={`https://www.google.com/maps/dir/?api=1&destination=${encodeURIComponent(office.query)}`}
              target="_blank"
              rel="noopener noreferrer"
              class="hover:underline text-base font-medium"
            >
              (Ver cómo llegar)
            </a>
          </div>

          <!-- WhatsApp Button -->
          <div class="pb-8 pt-4 text-center whitespace-nowrap overflow-x-auto no-scrollbar">
            <span class="text-gray-900 text-lg align-middle font-['Montserrat']">Puede escribirnos por</span>
            <a
              href={`https://api.whatsapp.com/send/?phone=${office.whatsapp}&text=Hola%2C+me+interesa+una+orientaci%C3%B3n+gratuita+sobre+quiebras+(${encodeURIComponent(office.city)})&type=phone_number&app_absent=0`}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-2 bg-[#34CD60] text-white px-2 py-1 rounded-[14px] hover:bg-[#1ebe5d] transition-all active:scale-95 shadow-sm align-middle"
            >
              <span class="text-xl font-medium font-['Montserrat']">Whatsapp</span>
              <svg
                xmlns="http://www.w3.org/2000/svg"
                viewBox="0 0 24 24"
                fill="currentColor"
                class="w-6 h-6"
              >
                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z" />
                <path d="M12 0C5.373 0 0 5.373 0 12c0 2.115.554 4.103 1.523 5.828L.057 23.885a.5.5 0 0 0 .606.625l6.248-1.634A11.942 11.942 0 0 0 12 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 21.818a9.808 9.808 0 0 1-5.031-1.384l-.36-.214-3.732.977.994-3.631-.235-.374A9.808 9.808 0 0 1 2.182 12C2.182 6.57 6.57 2.182 12 2.182S21.818 6.57 21.818 12 17.43 21.818 12 21.818z" />
              </svg>
            </a>
          </div>
        </div>
      ))
    }
  </div>

  <!-- CTA Bottom -->
  <div class="mt-12 text-center">
    <a
      href="https://quiebrasahora.com/v/index.html"
      class="inline-block px-10 py-4 bg-primary text-white font-bold text-sm tracking-widest uppercase rounded-none shadow-lg hover:bg-primary/90 active:scale-95 transition-all duration-200"
    >
      Conozca Más
    </a>
  </div>
</section>
</section>
