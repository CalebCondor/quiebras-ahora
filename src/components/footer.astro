---
import {
  Facebook,
  Twitter,
  Instagram,
  Linkedin,
  Mail,
  MapPin,
  Phone,
  ArrowRight,
} from "@lucide/astro";

const currentYear = new Date().getFullYear();
---

<footer class="bg-[#0f0f0f] text-white pt-24 pb-12 border-t border-white/5">
  <div class="max-w-[1400px] mx-auto px-8">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-16 mb-20">
      <!-- Brand Section -->
      <div class="flex flex-col gap-8">
        <div class="flex items-center gap-3">
          <img
            src="/images/logo.png"
            alt="Quiebras Ahora Logo"
            class="h-12 w-auto brightness-0 invert"
          />
        </div>
     
  
      </div>

      <div>
        <h4 class="text-xl font-bold mb-8 relative inline-block">
          Horario
          <span class="absolute -bottom-2 left-0 w-12 h-1 bg-primary"></span>
        </h4>
        <ul class="flex flex-col gap-6">
          <li class="flex items-start gap-4 text-white/60">
            
            <span>Lunes a Viernes<br />8:00 AM - 5:00 PM</span>
          </li>
          <li class="flex items-start gap-4 text-white/60">
          
            <span>Sábados<br />8:00 AM - 12:00 PM</span>
          </li>
        </ul>
      </div>
      <!-- Contact Info -->
      <div>
        <h4 class="text-xl font-bold mb-8 relative inline-block">
          Contacto
          <span class="absolute -bottom-2 left-0 w-12 h-1 bg-primary"></span>
        </h4>
        <ul class="flex flex-col gap-6">
          <li class="flex items-start gap-4 text-white/60">
          
            <span
              >Sedes en San Juan, <br />Bayamón y Caguas<br />Puerto Rico</span
            >
          </li>
          <li
            class="flex items-center gap-4 text-white/60 hover:text-white transition-colors cursor-pointer"
          >
            <a href="tel:7877874747" class="flex items-center gap-4">
              
              <span>(787) 787-4747</span>
            </a>
          </li>
        </ul>
      </div>

  
    </div>

    <!-- Bottom Bar -->
    <div
      class="pt-12 border-t border-white/5 flex flex-col md:flex-row justify-between items-center gap-8 text-[0.9rem] text-white/40"
    >
      <p>© {currentYear} Quiebras Ahora. Todos los derechos reservados.</p>
    </div>
  </div>
</footer>

<style>
  footer {
    position: relative;
    overflow: hidden;
  }

  /* Sutil gradiente para profundidad */
  footer::after {
    content: "";
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: radial-gradient(
      circle at 10% 10%,
      rgba(204, 0, 0, 0.03) 0%,
      transparent 40%
    );
    pointer-events: none;
  }
</style>
